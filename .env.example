# Base de datos PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=fastapi_parcial
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
SECRET_KEY=generar_con_python_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# MercadoPago - sandbox/test
MP_ACCESS_TOKEN=TEST-tu-access-token-de-mercadopago
MP_PUBLIC_KEY=TEST-tu-public-key-de-mercadopago
MP_WEBHOOK_URL=https://tu-subdominio.ngrok-free.dev/api/v1/pagos/webhook

# URLs
# FRONTEND_URL debe apuntar al store-app, no al admin-app.
# Si el store corre en 5173, usar 5173. Si corre en 5174, usar 5174.
FRONTEND_URL=http://localhost:5173

# NGROK_URL debe ser solo la URL base, sin /api/v1/...
NGROK_URL=https://tu-subdominio.ngrok-free.dev

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Logging
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# En desarrollo, INFO muestra el flujo normal de la app.
LOG_LEVEL=nivel-de-log